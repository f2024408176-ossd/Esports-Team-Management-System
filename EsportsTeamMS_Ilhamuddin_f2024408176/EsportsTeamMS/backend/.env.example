# ================================================
# Esports Team Management System – Environment Variables
# ================================================
# Copy this file to .env and fill in your values.
# NEVER commit your actual .env file to GitHub.

# Supabase PostgreSQL Connection URL
# Get from: Supabase Dashboard → Settings → Database → URI
DATABASE_URL=postgresql://postgres:[YOUR_PASSWORD]@db.[YOUR_PROJECT_REF].supabase.co:5432/postgres

# JWT Secret Key (use a long random string in production)
SECRET_KEY=esportsms-secret-key-change-this-in-production

# App Settings
APP_ENV=production
DEBUG=False
